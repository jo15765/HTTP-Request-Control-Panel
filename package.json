{
  "name": "http-client-gui",
  "version": "1.0.0",
  "description": "Postman-like HTTP client — Electron desktop app",
  "main": "electron-main.js",
  "author": "Johnathan Simpson",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.httpclient.gui",
    "productName": "HTTP Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "proxy-core.js",
      "security.js",
      "history-store.js",
      "package.json",
      "public/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
